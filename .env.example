HOTRADAR_DATABASE_PATH=data/hotspots.sqlite
HOTRADAR_WATCH_KEYWORDS_PATH=config/watch-keywords.json
HOTRADAR_COLLECTOR_MODE=hybrid
HOTRADAR_HTTP_TIMEOUT_SECONDS=8
HOTRADAR_SCHEDULED_REFRESH_MINUTES=30
HOTRADAR_MANUAL_REFRESH_COOLDOWN_SECONDS=60
HOTRADAR_SOURCE_MIN_REFRESH_SECONDS=300
HOTRADAR_ENABLE_SCHEDULER=1
HOTRADAR_REQUIRE_ADMIN_TOKEN=0
HOTRADAR_ADMIN_TOKEN=
HOTRADAR_LOG_FORMAT=json
HOTRADAR_LOG_LEVEL=INFO

# Optional local-only frontend convenience when admin token protection is enabled.
# Do not ship a public frontend with an embedded admin token.
VITE_HOTRADAR_ADMIN_TOKEN=
